{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchützenManager",
  "version": "0.1.3",
  "identifier": "de.schuetzenmanager.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../.. && npm run dev --workspace apps/frontend",
    "beforeBuildCommand": "cd ../.. && npm run build --workspace apps/frontend"
  },
  "app": {
    "windows": [
      {
        "title": "SchützenManager",
        "width": 1150,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/EinfachFabsTV/SchuetzenManager/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCNThDOTMyQUI2RkRCNkQKUldSdDIyK3JNc2xZNjVHNU5vNytnTlRmU1N2ajJLNE0wMnBBYXBCbysrTEUvM0tOTWo0cGw5SjkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/backend"],
    "externalBin": ["binaries/schuetzenmanager-backend"],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
