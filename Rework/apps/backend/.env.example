DATABASE_URL="file:./dev.db"
PORT=3001

# Auth (opt-in, only relevant for central hosting - see TECHNICAL.md)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production

# Mail (used by POST /users to notify new accounts - see src/mail.ts).
# Leave SMTP_HOST unset to fall back to a no-op JSON transport for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@schuetzenmanager.local
